# ══════════════════════════════════════════════════════════════════════════════
# SERVER — variáveis de ambiente (Bun)
# Copie para .env e preencha os valores.
# NUNCA commite .env — ele está no .gitignore.
# Em produção, defina como secrets no painel do Render.
# ══════════════════════════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────────────────────────
# Porta HTTP/WebSocket. O Render injeta PORT automaticamente.
PORT=3001

# Ambiente: development | production
NODE_ENV=development

# ── Username Bloom filter ─────────────────────────────────────────────────────
# Bump on every deploy (git SHA, counter, timestamp — anything unique per deploy).
# Each epoch has its own username namespace — no cross-deploy collisions, no persistence needed.
# On Render: $RENDER_GIT_COMMIT
BLOOM_EPOCH=1

# ── Identity signing ──────────────────────────────────────────────────────────
# 64-character hex string (32 bytes) used to HMAC-sign guest identity tokens.
# Generate with: openssl rand -hex 32
# REQUIRED in production — if unset, an ephemeral key is used and all sessions
# are invalidated on every server restart.
PLAYER_SECRET=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Credenciais do painel admin em /admin (no front).
# Em produção, use valores fortes e defina como GitHub Secrets.
ADMIN_USER=admin
ADMIN_PASS=changeme

# ── New Relic — Observabilidade via OpenTelemetry ────────────────────────────
# Obtenha em: one.newrelic.com → API Keys → Ingest - License
# Deixe em branco para desabilitar em desenvolvimento local.
NEW_RELIC_LICENSE_KEY=

# Endpoint OTLP do New Relic:
#   US: https://otlp.nr-data.net
#   EU: https://otlp.eu01.nr-data.net
NEW_RELIC_OTLP_ENDPOINT=https://otlp.nr-data.net

# Nome do serviço exibido no New Relic APM
NEW_RELIC_APP_NAME=poker-server
