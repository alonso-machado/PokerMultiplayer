# ══════════════════════════════════════════════════════════════════════════════
# FRONT — variáveis de ambiente (Vite/React)
# Copie para .env.local e preencha os valores.
# Todas as vars devem começar com VITE_ para ficarem acessíveis no browser.
# NUNCA commite .env.local — ele está no .gitignore.
# ══════════════════════════════════════════════════════════════════════════════

# ── WebSocket do servidor ─────────────────────────────────────────────────────
# URL do WebSocket do servidor de jogo.
# Local:      ws://localhost:3001/ws
# Produção:   wss://seu-app.onrender.com/ws
VITE_WS_URL=ws://localhost:3001/ws

# ── HTTP do servidor (API admin, torneio público) ─────────────────────────────
# Local:      http://localhost:3001
# Produção:   https://seu-app.onrender.com
VITE_SERVER_URL=http://localhost:3001

# ── PostHog — Analytics & Product Insights ───────────────────────────────────
# Obtenha em: app.posthog.com → Project Settings → Project API Key
# Deixe em branco para desabilitar analytics em desenvolvimento local.
VITE_POSTHOG_KEY=

# Host PostHog (US ou EU):
#   US: https://us.i.posthog.com
#   EU: https://eu.i.posthog.com
VITE_POSTHOG_HOST=https://us.i.posthog.com
